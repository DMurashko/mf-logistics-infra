# ============================================================
# Scaleway Production Environment Variables
# ============================================================
# Copy this file to .env.scaleway, fill in real values,
# then scp to the server:
#   scp -i ~/.ssh/scw_deploy_key .env.scaleway root@<IP>:/opt/logistics-app/.env
#
# NEVER commit .env.scaleway to version control!
# ============================================================

# ── Scaleway Container Registry ──
SCW_REGISTRY=rg.fr-par.scw.cloud
SCW_NAMESPACE=logistics-test-app
SCW_SECRET_KEY=CHANGE_ME_YOUR_SCALEWAY_SECRET_KEY

# ── Image Tags (commit SHA or "latest") ──
IMAGE_TAG=latest

# ── Public Domain / IP ──
# The public URL where the app is accessible (e.g. http://<INSTANCE_IP> or https://yourdomain.com)
PUBLIC_URL=http://YOUR_INSTANCE_IP

# ── Frontend Micro-Frontend URLs ──
# These are resolved by the browser, so they must point to the public ingress.
# NOTE: .env does not support variable interpolation — use the actual IP/domain below.
VITE_UI_LIBRARY_URL=http://YOUR_INSTANCE_IP/mf/ui-library/dist/remoteEntry.js
VITE_LOGIN_APP_URL=http://YOUR_INSTANCE_IP/mf/login/remoteEntry.js
VITE_DASHBOARD_APP_URL=http://YOUR_INSTANCE_IP/mf/dashboard/remoteEntry.js

# ── Backend API URL (browser-resolved) ──
VITE_API_URL=http://YOUR_INSTANCE_IP/api

# ── PostgreSQL ──
POSTGRES_USER=warehouseuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=warehousedb
DATABASE_URL=postgresql://warehouseuser:CHANGE_ME_STRONG_PASSWORD@postgres:5432/warehousedb?schema=public

# ── Backend JWT ──
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS_DIFFERENT_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
