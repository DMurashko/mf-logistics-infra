# ============================================================
# Scaleway Production Environment Variables
# ============================================================
#
# Secrets (POSTGRES_PASSWORD, JWT_SECRET, JWT_REFRESH_SECRET)
# are stored in Scaleway Secret Manager under path /logistics/
# and fetched automatically by the deploy workflow.
#
# This file documents the full .env shape that the deploy
# workflow generates on the server at /opt/logistics-app/.env
#
# For manual deployment, copy to .env.scaleway, fill in values,
# then scp to the server as .env
# ============================================================

# ── Scaleway Container Registry ──
SCW_REGISTRY=some.scw.cloud
SCW_NAMESPACE=some-app

# ── Image Tags (commit SHA or "latest") ──
IMAGE_TAG=latest

# ── Public Domain / IP ──
# The public URL where the app is accessible (e.g. http://<INSTANCE_IP> or https://yourdomain.com)
PUBLIC_URL=http://YOUR_INSTANCE_IP

# ── Frontend Micro-Frontend URLs ──
# These are resolved by the browser, so they must point to the public ingress.
VITE_UI_LIBRARY_URL=${PUBLIC_URL}/mf/ui-library/dist/remoteEntry.js
VITE_LOGIN_APP_URL=${PUBLIC_URL}/mf/login/remoteEntry.js
VITE_DASHBOARD_APP_URL=${PUBLIC_URL}/mf/dashboard/remoteEntry.js

# ── Backend API URL (browser-resolved) ──
VITE_API_URL=${PUBLIC_URL}/api

# ── PostgreSQL ──
POSTGRES_USER=warehouseuser
POSTGRES_PASSWORD=<from SCW Secret Manager: /logistics/POSTGRES_PASSWORD>
POSTGRES_DB=warehousedb
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# ── Backend JWT ──
JWT_SECRET=<from SCW Secret Manager: /logistics/JWT_SECRET>
JWT_REFRESH_SECRET=<from SCW Secret Manager: /logistics/JWT_REFRESH_SECRET>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
